<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Company.TestProject1</RootNamespace>
    <TargetFramework Condition="'$(TargetFrameworkOverride)' == ''">net11.0</TargetFramework>
    <TargetFramework Condition="'$(TargetFrameworkOverride)' != ''">TargetFrameworkOverride</TargetFramework>
    <IsPackable Condition="'$(EnablePack)' == 'true'">true</IsPackable>
    <IsPackable Condition="'$(EnablePack)' != 'true'">false</IsPackable>
<!--#if (XUnitVersion == "v3")-->
    <OutputType>Exe</OutputType>
<!--#endif-->
<!--#if (XUnitVersion == "v3" && TestRunner == "Microsoft.Testing.Platform")-->
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
<!--#endif-->
  </PropertyGroup>


</Project>
