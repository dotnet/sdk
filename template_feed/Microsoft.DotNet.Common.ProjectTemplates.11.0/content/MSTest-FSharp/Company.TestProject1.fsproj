<!--#if (UseMSTestSdk)-->
<Project Sdk="MSTest.Sdk/4.2.3">

  <PropertyGroup>
    <TargetFramework Condition="'$(TargetFrameworkOverride)' == ''">net11.0</TargetFramework>
    <TargetFramework Condition="'$(TargetFrameworkOverride)' != ''">TargetFrameworkOverride</TargetFramework>
    <RootNamespace Condition="'$(name)' != '$(name{-VALUE-FORMS-}safe_namespace)'">Company.TestProject1</RootNamespace>
    <LangVersion Condition="'$(langVersion)' != ''">$(ProjectLanguageVersion)</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
<!--#if (TestRunner == "VSTest")-->
    <UseVSTest>true</UseVSTest>
  </PropertyGroup>
<!--#if (CoverageTool == "coverlet")-->

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
  </ItemGroup>
<!--#endif-->
<!--#else-->
    <TestingExtensionsProfile Condition=" '$(ExtensionsProfile)' != 'Default' ">$(ExtensionsProfile)</TestingExtensionsProfile>
<!--#if (ExplicitProgramFile)-->
    <GenerateTestingPlatformEntryPoint>false</GenerateTestingPlatformEntryPoint>
<!--#endif-->
  </PropertyGroup>
<!--#endif-->

  <ItemGroup>
    <Compile Include="MSTestSettings.fs" />
    <Compile Include="Test1.fs" />
<!--#if (ExplicitProgramFile && TestRunner == "Microsoft.Testing.Platform")-->
    <Compile Include="Program.fs" />
<!--#endif-->
  </ItemGroup>

<!--#if (ExplicitProgramFile && TestRunner == "Microsoft.Testing.Platform")-->
  <!-- F# requires the [<EntryPoint>] function to be in the last file of the
       compilation. Re-order Program.fs to come after any files injected by the
       MSTest source generator (for example, SelfRegisteredExtensions.fs). -->
  <Target Name="_EnsureProgramFsIsLast" BeforeTargets="CoreCompile">
    <ItemGroup>
      <Compile Remove="Program.fs" />
      <Compile Include="Program.fs" />
    </ItemGroup>
  </Target>
<!--#endif-->

</Project>
<!--#else-->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework Condition="'$(TargetFrameworkOverride)' == ''">net11.0</TargetFramework>
    <TargetFramework Condition="'$(TargetFrameworkOverride)' != ''">TargetFrameworkOverride</TargetFramework>
    <RootNamespace Condition="'$(name)' != '$(name{-VALUE-FORMS-}safe_namespace)'">Company.TestProject1</RootNamespace>
    <LangVersion Condition="'$(langVersion)' != ''">$(ProjectLanguageVersion)</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
<!--#if (TestRunner == "Microsoft.Testing.Platform")-->
    <EnableMSTestRunner>true</EnableMSTestRunner>
    <OutputType>Exe</OutputType>
<!--#if (ExplicitProgramFile)-->
    <GenerateTestingPlatformEntryPoint>false</GenerateTestingPlatformEntryPoint>
<!--#endif-->
<!--#endif-->
  </PropertyGroup>

  <ItemGroup>
<!--#if (CoverageTool == "coverlet")-->
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
<!--#endif-->
    <PackageReference Include="MSTest" Version="4.2.3" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.VisualStudio.TestTools.UnitTesting" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="MSTestSettings.fs" />
    <Compile Include="Test1.fs" />
<!--#if (ExplicitProgramFile && TestRunner == "Microsoft.Testing.Platform")-->
    <Compile Include="Program.fs" />
<!--#endif-->
  </ItemGroup>

<!--#if (ExplicitProgramFile && TestRunner == "Microsoft.Testing.Platform")-->
  <!-- F# requires the [<EntryPoint>] function to be in the last file of the
       compilation. Re-order Program.fs to come after any files injected by the
       MSTest source generator (for example, SelfRegisteredExtensions.fs). -->
  <Target Name="_EnsureProgramFsIsLast" BeforeTargets="CoreCompile">
    <ItemGroup>
      <Compile Remove="Program.fs" />
      <Compile Include="Program.fs" />
    </ItemGroup>
  </Target>
<!--#endif-->

</Project>
<!--#endif-->
