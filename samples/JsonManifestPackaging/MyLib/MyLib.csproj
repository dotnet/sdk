<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <!-- Mark js/framework*.js as a framework asset for testing materialization -->
    <StaticWebAssetFrameworkPattern>js/framework*</StaticWebAssetFrameworkPattern>
  </PropertyGroup>

  <!-- Group definition: tag server-rendering.js with rendering=server -->
  <ItemGroup>
    <StaticWebAssetGroupDefinition Include="rendering" Value="server" IncludePattern="js/server-rendering*" />
  </ItemGroup>

</Project>
