<!--
  Remove once https://github.com/dotnet/arcade/issues/16424 is fixed.
  This is a repo-local override of the arcade XUnitV3.targets that uses the xunit.v3.mtp-v2 adapter
  instead of xunit.v3 (which brings in the mtp-v1 adapter). This is necessary because the repo pins
  Microsoft.Testing.Platform to 2.x via the testfx dependency flow, and xunit.v3.core.mtp-v1 is only
  compatible with Microsoft.Testing.Platform 1.x (it doesn't implement the updated interface methods
  added in MTP 2.x, such as ITelemetryCollector.LogEventAsync with CancellationToken and
  IOutputDevice.DisplayAsync with the updated signature).
-->
<Project>

  <PropertyGroup>
    <UseVSTestRunner Condition="'$(UseVSTestRunner)' != 'true'">false</UseVSTestRunner>

    <!-- Default to using MTP -->
    <UseMicrosoftTestingPlatformRunner Condition="'$(UseMicrosoftTestingPlatformRunner)' == ''">true</UseMicrosoftTestingPlatformRunner>
  </PropertyGroup>

  <ItemGroup>
    <!-- Use xunit.v3.mtp-v2 instead of xunit.v3 to get the MTP v2-compatible adapter -->
    <PackageReference Include="xunit.v3.mtp-v2" Version="$(XUnitV3Version)" IsImplicitlyDefined="true" PrivateAssets="all" Publish="true" />
    <PackageReference Include="xunit.runner.visualstudio" Version="$(XUnitRunnerVisualStudioVersion)" IsImplicitlyDefined="true" PrivateAssets="all" Publish="true"/>
  </ItemGroup>

  <ItemGroup Condition="'$(UseMicrosoftTestingPlatformRunner)' == 'true'">
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" Version="$(MicrosoftTestingPlatformVersion)" IsImplicitlyDefined="true" PrivateAssets="all" Publish="true" />
    <PackageReference Include="Microsoft.Testing.Platform.MSBuild" Version="$(MicrosoftTestingPlatformVersion)" IsImplicitlyDefined="true" PrivateAssets="all" Publish="true" />
    <PackageReference Include="Microsoft.Testing.Platform" Version="$(MicrosoftTestingPlatformVersion)" IsImplicitlyDefined="true" PrivateAssets="all" Publish="true" />
  </ItemGroup>

  <PropertyGroup>
    <_ArcadeXUnitV3Dir>$(NuGetPackageRoot)microsoft.dotnet.arcade.sdk/$(MicrosoftDotNetArcadeSdkVersion)/tools/XUnitV3/</_ArcadeXUnitV3Dir>
    <XUnitDesktopSettingsFile Condition="'$(XUnitDesktopSettingsFile)' == ''">$(_ArcadeXUnitV3Dir)xunit.runner.json</XUnitDesktopSettingsFile>
    <XUnitCoreSettingsFile Condition="'$(XUnitCoreSettingsFile)' == ''">$(_ArcadeXUnitV3Dir)xunit.runner.json</XUnitCoreSettingsFile>
  </PropertyGroup>

  <!--
    Include settings file (xunit.runner.json) if specified.
  -->
  <ItemGroup>
    <None Include="$(XUnitDesktopSettingsFile)"
          CopyToOutputDirectory="PreserveNewest"
          Visible="false"
          Condition="'$(XUnitDesktopSettingsFile)' != '' and '$(TargetFrameworkIdentifier)' == '.NETFramework'" />

    <None Include="$(XUnitCoreSettingsFile)"
          CopyToOutputDirectory="PreserveNewest"
          Visible="false"
          Condition="'$(XUnitCoreSettingsFile)' != '' and '$(TargetFrameworkIdentifier)' == '.NETCoreApp'" />
  </ItemGroup>

  <Import Project="$(_ArcadeXUnitV3Dir)XUnitV3.Runner.targets" Condition="!$(UseVSTestRunner)"/>
  <Import Project="$(NuGetPackageRoot)microsoft.dotnet.arcade.sdk/$(MicrosoftDotNetArcadeSdkVersion)/tools/VSTest.targets" Condition="$(UseVSTestRunner)"/>

</Project>
