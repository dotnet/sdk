<Project>

  <!--
    Shared sources, resources, and package references for the AOT CLI bridge.
    Imported by both dotnet-aot.csproj and dotnet-aot.Tests.csproj to keep the
    two consumers in sync. Parser.cs references the 'sdk check' command, so the
    command's sources, resources, and package dependency must be shared as well,
    otherwise the test project (which compiles Parser.cs) fails to build.

    Only includes files that compile without internal NativeWrapper dependencies.
    NativeEntryPoint.cs and ManagedHost.cs are added separately by each consumer
    because ManagedHost.cs requires InternalsVisibleTo access to NativeWrapper.
  -->
  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\CommandLineInfo.cs" Link="CommandLineInfo.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\Parser.cs" Link="Parser.cs" />
    <Compile Include="$(RepoRoot)src\Common\EnvironmentVariableNames.cs" LinkBase="Common" />

    <!-- sdk check command infrastructure -->
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\CommandBase.cs" Link="CommandBase.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\PrintableTable.cs" Link="PrintableTable.cs" />

    <!-- sdk check command -->
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\Commands\Sdk\Check\SdkCheckCommand.cs" Link="Commands\Sdk\Check\SdkCheckCommand.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\Commands\Sdk\Check\IProductCollectionProvider.cs" Link="Commands\Sdk\Check\IProductCollectionProvider.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\Commands\Sdk\Check\ProductCollectionProvider.cs" Link="Commands\Sdk\Check\ProductCollectionProvider.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\Commands\Sdk\Check\BundleOutputWriter.cs" Link="Commands\Sdk\Check\BundleOutputWriter.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\Commands\Sdk\Check\SdkOutputWriter.cs" Link="Commands\Sdk\Check\SdkOutputWriter.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)..\dotnet\Commands\Sdk\Check\RuntimeOutputWriter.cs" Link="Commands\Sdk\Check\RuntimeOutputWriter.cs" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\dotnet\CliStrings.resx" LinkBase="Resources" GenerateSource="true" Namespace="Microsoft.DotNet.Cli" />
    <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\dotnet\Commands\CliCommandStrings.resx" LinkBase="Resources" GenerateSource="true" Namespace="Microsoft.DotNet.Cli.Commands" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Deployment.DotNet.Releases" />
  </ItemGroup>

</Project>
