<Project>
  <PropertyGroup>
    <!-- Pin RepoRoot to the real repo root so Arcade does not infer it from this directory's global.json. -->
    <RepoRoot>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)', '..', '..'))</RepoRoot>
  </PropertyGroup>
  <!-- Important - this Import needs to happen _after_ the RepoRoot is set so that Arcade doesn't set a bunch of incorrect properties.
       Loading the repo-level D.B.props causes the Arcade SDK to be loaded, which computes load-bearing properties from this value -->
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />
  <PropertyGroup>
    <!-- Shared version for dotnetup CLI and Microsoft.Dotnet.Installation library -->
    <DotnetupVersionPrefix>0.1.3</DotnetupVersionPrefix>
    <DotnetupPreReleaseVersionLabel>preview</DotnetupPreReleaseVersionLabel>
  </PropertyGroup>

  <!-- Shared properties for the dotnetup family of projects (dotnetup, dotnetup.Library,
       Microsoft.Dotnet.Installation). Individual projects can still override these.
       TargetFramework is intentionally NOT set here — some tooling gets confused when
       TargetFramework isn't set directly in the project file. -->
  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Versioning -->
    <VersionPrefix>$(DotnetupVersionPrefix)</VersionPrefix>
    <PreReleaseVersionLabel>$(DotnetupPreReleaseVersionLabel)</PreReleaseVersionLabel>

    <!-- Style/analysis warnings should only break the dedicated style-check leg, not the bootstrap toolset build.
         EnforceCodeStyleInBuild=false  prevents IDE* code-style analyzers from running during build.
         CodeAnalysisTreatWarningsAsErrors=false  keeps CA* analyzer warnings as warnings instead of errors.
         WarningsNotAsErrors demotes Meziantou MA0051 (method too long) so it stays a warning under TreatWarningsAsErrors. -->
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
    <CodeAnalysisTreatWarningsAsErrors>false</CodeAnalysisTreatWarningsAsErrors>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);MA0051</WarningsNotAsErrors>
  </PropertyGroup>
</Project>
