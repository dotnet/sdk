<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- This project is a library; its compiled assembly is consumed by:
         - src/Installer/dotnetup/dotnetup.csproj (the NativeAOT Exe that ships as the
           dotnetup standalone executable), and
         - test/dotnetup.Tests/dotnetup.Tests.csproj (via InternalsVisibleTo).
         The Exe-style entry point (`DotnetupProgram.Main`) lives in this assembly so the
         AOT Exe can forward to it without duplicating the bootstrap logic. Keeping this
         project a Library avoids the SDK's NETSDK1150 / NETSDK1151 errors that would
         result from an Exe-to-Exe ProjectReference between dotnetup (self-contained)
         and a non-self-contained dotnetup.Library that tests still need to reference. -->
    <OutputType>Library</OutputType>
    <TargetFramework>$(SdkTargetFramework)</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- IsAotCompatible (rather than PublishAot) enables AOT analyzer warnings without
         forcing this Library project to AOT-publish on its own — the publish happens in
         dotnetup.csproj, which references this assembly. -->
    <IsAotCompatible>true</IsAotCompatible>
    <TrimmerSingleWarn>false</TrimmerSingleWarn>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ControlFlowGuard>Guard</ControlFlowGuard>


    <!-- Strong naming not needed on .NET Core -->
    <NoWarn>$(NoWarn);CS8002;CS1591</NoWarn>

    <!-- Style/analysis warnings should only break the dedicated style-check leg, not the bootstrap toolset build.
         EnforceCodeStyleInBuild=false  prevents IDE* code-style analyzers from running during build.
         CodeAnalysisTreatWarningsAsErrors=false  keeps CA* analyzer warnings as warnings instead of errors.
         WarningsNotAsErrors demotes Meziantou MA0051 (method too long) so it stays a warning under TreatWarningsAsErrors. -->
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
    <CodeAnalysisTreatWarningsAsErrors>false</CodeAnalysisTreatWarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);MA0051</WarningsNotAsErrors>

    <!-- dotnetup versioning -->
    <VersionPrefix>$(DotnetupVersionPrefix)</VersionPrefix>
    <PreReleaseVersionLabel>$(DotnetupPreReleaseVersionLabel)</PreReleaseVersionLabel>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <PropertyGroup>
    <RootNamespace>Microsoft.DotNet.Tools.Bootstrapper</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="dotnetup" />
    <InternalsVisibleTo Include="dotnetup.Tests" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(RepoRoot)src\Cli\dotnet\Telemetry\TelemetryDiskLogger.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\Microsoft.DotNet.Cli.Definitions\Telemetry\CIEnvironmentDetectorForTelemetry.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\dotnet\Telemetry\DevDeviceIDGetter.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\dotnet\Telemetry\DockerContainerDetectorForTelemetry.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\dotnet\Telemetry\IDockerContainerDetector.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\Microsoft.DotNet.Cli.Definitions\Telemetry\EnvironmentDetectionRule.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\Microsoft.DotNet.Cli.CoreUtils\EnvironmentVariableParser.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\Microsoft.DotNet.Cli.Definitions\Telemetry\ICIEnvironmentDetector.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\dotnet\Telemetry\ILLMEnvironmentDetector.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\dotnet\Telemetry\LLMEnvironmentDetectorForTelemetry.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\Microsoft.DotNet.Cli.Utils\Env.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\Microsoft.DotNet.Cli.Utils\EnvironmentProvider.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\Microsoft.DotNet.Cli.Utils\Extensions\CollectionsExtensions.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\Microsoft.DotNet.Cli.Utils\IEnvironmentProvider.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\dotnet\AutomaticEncodingRestorer.cs" LinkBase="Shared" />
    <Compile Include="$(RepoRoot)src\Cli\Microsoft.DotNet.Cli.Utils\UILanguageOverride.cs" LinkBase="Shared" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Meziantou.Analyzer" Condition="'$(DotNetBuildSourceOnly)' != 'true'" PrivateAssets="all" IncludeAssets="runtime; build; native; contentfiles; analyzers" />
    <PackageReference Include="Microsoft.Deployment.DotNet.Releases" />
    <PackageReference Include="System.CommandLine" />
    <PackageReference Include="Spectre.Console" />
    <!-- Telemetry packages (AOT compatible) — mirrors SDK's dotnet.csproj -->
    <PackageReference Include="Azure.Monitor.OpenTelemetry.Exporter" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="OpenTelemetry" />
    <PackageReference Include="OpenTelemetry.Exporter.Console" />
    <PackageReference Include="OpenTelemetry.Exporter.InMemory" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.Dotnet.Installation" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Microsoft.Dotnet.Installation\Microsoft.Dotnet.Installation.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Strings.resx" GenerateSource="true" Namespace="Microsoft.DotNet.Tools.Bootstrapper" />
  </ItemGroup>

</Project>
