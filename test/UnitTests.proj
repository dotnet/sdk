<Project>
  <!--
    PoC: Run SDK tests locally on the AzDO agent instead of sending them to Helix.
    Uses explicit Helix SDK imports so we can override CoreTest after Sdk.targets.

    The build/publish infrastructure from XUnitRunner.targets is preserved so the
    EXACT same test assemblies are built.  Only the execution phase is replaced:
    instead of SendHelixJob, we run 'dotnet test' on each published assembly
    directly on the agent, in parallel via MSBuild batching.
  -->
  <Import Project="Sdk.props" Sdk="Microsoft.DotNet.Helix.Sdk" />

  <PropertyGroup>
    <!-- Keep IncludeDotNetCli=false; we're running tests with the built SDK directly -->
    <IncludeDotNetCli>false</IncludeDotNetCli>
    <XUnitWorkItemTimeout>02:00:00</XUnitWorkItemTimeout>
    <!-- Results directory for TRX files (picked up by PublishTestResults in AzDO) -->
    <LocalTestResultsDir Condition="'$(LocalTestResultsDir)' == ''">$(RepoRoot)artifacts/TestResults/$(Configuration)</LocalTestResultsDir>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Remove="AwesomeAssertions" />
  </ItemGroup>

  <ItemGroup>
    <SDKCustomXUnitProject Include="**\*.Tests.csproj" Exclude="**\*.AoT.Tests.csproj;TestAssets\**\*.Tests.csproj" />
    <SDKCustomXUnitProject Include="$(RepoRoot)src\Microsoft.CodeAnalysis.NetAnalyzers\tests\**\*.*Tests.csproj" />

    <!-- Projects suffixed with UnitTests or IntegrationTests are not matched by *.Tests.csproj above, so include them with a separate glob. -->
    <SDKCustomXUnitProject Include="**\*UnitTests.csproj;**\*IntegrationTests.csproj" Exclude="TestAssets\**\*" />

    <!-- Don't run MSI installation tests in Helix / CI -->
    <SdkCustomXUnitProject Remove="dotnet-MsiInstallation.Tests\**\*" />

    <!-- dotnet-format unit tests are run under the DOTNET_FORMAT pipeline section. -->
    <SDKCustomXUnitProject Remove="dotnet-format.UnitTests\dotnet-format.UnitTests.csproj" />

    <!-- ApiCompat integration tests are only run with TestFullMSBuild=true (see below). -->
    <SDKCustomXUnitProject Remove="Microsoft.DotNet.ApiCompat.IntegrationTests\Microsoft.DotNet.ApiCompat.IntegrationTests.csproj" />

    <!-- Filter out .NET Framework only test projects and add them manually. -->
    <SDKCustomXUnitProject Remove="Microsoft.DotNet.MSBuildSdkResolver.Tests\Microsoft.DotNet.MSBuildSdkResolver.Tests.csproj" />
  </ItemGroup>

  <!-- When TestFullMSBuild=true, include the .NET Framework tests. .NETCoreApp tests are also executed
       as that validates running tests with desktop msbuild. -->
  <ItemGroup Condition="'$(TestFullMSBuild)' == 'true'">
    <SDKCustomXUnitProject Include="
      Microsoft.DotNet.ApiCompat.IntegrationTests\Microsoft.DotNet.ApiCompat.IntegrationTests.csproj;
      Microsoft.DotNet.ApiCompat.Tests\Microsoft.DotNet.ApiCompat.Tests.csproj;
      Microsoft.DotNet.ApiCompatibility.Tests\Microsoft.DotNet.ApiCompatibility.Tests.csproj;
      Microsoft.DotNet.ApiSymbolExtensions.Tests\Microsoft.DotNet.ApiSymbolExtensions.Tests.csproj;
      Microsoft.DotNet.MSBuildSdkResolver.Tests\Microsoft.DotNet.MSBuildSdkResolver.Tests.csproj;
      Microsoft.DotNet.PackageValidation.Tests\Microsoft.DotNet.PackageValidation.Tests.csproj;
      Microsoft.DotNet.TemplateLocator.Tests\Microsoft.DotNet.TemplateLocator.Tests.csproj;
      Microsoft.NET.Sdk.Publish.Tasks.Tests\Microsoft.NET.Sdk.Publish.Tasks.Tests.csproj;
      Microsoft.NET.Sdk.WorkloadManifestReader.Tests\Microsoft.NET.Sdk.WorkloadManifestReader.Tests.csproj;
      Microsoft.Win32.Msi.Tests\Microsoft.Win32.Msi.Tests.csproj"
                           TargetFramework="net472"
                           RuntimeTargetFramework="net472" />
  </ItemGroup>

  <ItemGroup Condition="'$(RunAoTTests)' == 'true'">
    <SDKCustomXUnitProject Remove="@(SDKCustomXUnitProject)" />
    <SDKCustomXUnitProject Include="**\*.AoT.Tests.csproj" />
  </ItemGroup>

  <!-- MethodLimitMultiplier metadata is irrelevant for local execution (no sharding),
       but we keep it so the project list stays byte-identical with the original. -->
  <ItemGroup>
    <SDKCustomXUnitProject Update="$(RepoRoot)src\Microsoft.CodeAnalysis.NetAnalyzers\tests\**\*.*Tests.csproj">
      <MethodLimitMultiplier>5</MethodLimitMultiplier>
    </SDKCustomXUnitProject>
    <SDKCustomXUnitProject Update="TemplateEngine\**\*.csproj;**\Microsoft.TemplateEngine.Cli.UnitTests.csproj">
      <MethodLimitMultiplier>20</MethodLimitMultiplier>
    </SDKCustomXUnitProject>
    <SDKCustomXUnitProject Update="**\Microsoft.DotNet.ApiCompatibility.Tests.csproj;**\Microsoft.DotNet.ApiDiff.Tests.csproj;**\Microsoft.DotNet.ApiSymbolExtensions.Tests.csproj;**\Microsoft.DotNet.GenAPI.Tests.csproj">
      <MethodLimitMultiplier>10</MethodLimitMultiplier>
    </SDKCustomXUnitProject>
  </ItemGroup>

  <!-- We still need to set a HelixTargetQueue so XUnitRunner.targets' IsPosixShell
       logic works (it uses HelixTargetQueue to determine shell type for the build step).
       We just set it to a descriptive value; it will never be sent to Helix. -->
  <ItemGroup>
    <HelixTargetQueue Condition="'$(CustomHelixTargetQueue)' != ''" Include="$(CustomHelixTargetQueue)" />
    <HelixTargetQueue Condition="'$(CustomHelixTargetQueue)' == '' and $([MSBuild]::IsOSPlatform('Windows'))" Include="windows.amd64.local" />
    <HelixTargetQueue Condition="'$(CustomHelixTargetQueue)' == '' and !$([MSBuild]::IsOSPlatform('Windows'))" Include="linux.amd64.local" />
  </ItemGroup>

  <!-- Import XUnitRunner.targets for Restore + Build/Publish of test projects.
       This populates PublishDirectory and TargetPath metadata on SDKCustomXUnitProject items.
       The CreateSDKCustomXUnitWorkItems target from XUnitRunner.targets will be
       overridden below (it runs BeforeTargets=CoreTest, but we redefine CoreTest). -->
  <Import Project="xunit-runner\XUnitRunner.targets" />

  <!-- Import Helix SDK targets to get the target framework (CoreBuild, Restore, etc.) -->
  <Import Project="Sdk.targets" Sdk="Microsoft.DotNet.Helix.Sdk" />

  <!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║  OVERRIDE: Replace Helix CoreTest with local parallel test execution   ║
    ╚══════════════════════════════════════════════════════════════════════════╝

    This target REPLACES the Helix SDK's CoreTest (which calls SendHelixJob).
    Because it is defined AFTER the Sdk.targets import, MSBuild uses this definition.

    The CreateSDKCustomXUnitWorkItems target (BeforeTargets=CoreTest) still runs
    and creates HelixWorkItem items, but we ignore them.  Instead, we iterate the
    published SDKCustomXUnitProject items and run 'dotnet test' on each assembly.
  -->
  <Target Name="CoreTest">
    <MakeDir Directories="$(LocalTestResultsDir)" />

    <Message Importance="High" Text="" />
    <Message Importance="High" Text="╔══════════════════════════════════════════════════════════════╗" />
    <Message Importance="High" Text="║  LOCAL TEST EXECUTION (PoC - No Helix)                      ║" />
    <Message Importance="High" Text="║  Running @(SDKCustomXUnitProject->Count()) test assemblies on the local agent  ║" />
    <Message Importance="High" Text="╚══════════════════════════════════════════════════════════════╝" />
    <Message Importance="High" Text="" />
    <Message Importance="High" Text="Results directory: $(LocalTestResultsDir)" />
    <Message Importance="High" Text="" />

    <!-- List all test projects that will be run -->
    <Message Importance="High" Text="  ▸ %(SDKCustomXUnitProject.Filename) → %(SDKCustomXUnitProject.PublishDirectory)" />

    <!-- Build a wrapper item for each test project pointing to RunSingleLocalTest.proj
         with per-project properties.  MSBuild will run these in parallel across nodes
         when invoked with /maxcpucount. -->
    <ItemGroup>
      <_LocalTestWrapper Include="@(SDKCustomXUnitProject->'$(MSBuildThisFileDirectory)xunit-runner/RunSingleLocalTest.proj')">
        <AdditionalProperties>
          TestProjectPath=%(SDKCustomXUnitProject.Identity);
          TestProjectName=%(SDKCustomXUnitProject.Filename);
          PublishDir=%(SDKCustomXUnitProject.PublishDirectory);
          LocalTestResultsDir=$(LocalTestResultsDir);
          Configuration=$(Configuration);
          TestDotNetRoot=$(TestHostDotNetRoot)
        </AdditionalProperties>
      </_LocalTestWrapper>
    </ItemGroup>

    <MSBuild Projects="@(_LocalTestWrapper)"
             BuildInParallel="true"
             ContinueOnError="ErrorAndContinue" />

    <Message Importance="High" Text="" />
    <Message Importance="High" Text="══════════════════════════════════════════════════════════════" />
    <Message Importance="High" Text="  ALL LOCAL TEST EXECUTIONS COMPLETE" />
    <Message Importance="High" Text="  TRX results: $(LocalTestResultsDir)" />
    <Message Importance="High" Text="══════════════════════════════════════════════════════════════" />
  </Target>

  <!--
    Disable the Helix-specific targets that are no longer needed.
    CopyHelixFiles and AppendHelixPreCommand prepare payloads for Helix agents.
  -->
  <Target Name="CopyHelixFiles" />
  <Target Name="AppendHelixPreCommand" />

</Project>
