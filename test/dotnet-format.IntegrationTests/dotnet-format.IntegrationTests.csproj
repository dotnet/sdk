<Project Sdk="MSTest.Sdk">

  <PropertyGroup>
    <TargetFramework>$(SdkTargetFramework)</TargetFramework>
    <RollForward>LatestMajor</RollForward>
    <!-- Tests are resource-intensive (git clones, restores) and must run serially. -->
    <MSTestParallelizeScope>None</MSTestParallelizeScope>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Microsoft.NET.TestFramework.MSTest\Microsoft.NET.TestFramework.MSTest.csproj" />
  </ItemGroup>

</Project>
