<Project Sdk="MSTest.Sdk">

  <PropertyGroup>
    <!-- Opts this project out of the xUnit-specific defaults applied by test/Directory.Build.targets.
         MSTest.Sdk wires up MSTest + Microsoft.Testing.Platform (MTP) itself. -->
    <UseMSTestSdk>true</UseMSTestSdk>

    <TargetFramework>$(SdkTargetFramework)</TargetFramework>
    <RootNamespace>Microsoft.DotNet.Watch.Aspire.UnitTests</RootNamespace>
    <StrongNameKeyId>MicrosoftAspNetCore</StrongNameKeyId>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Dotnet.Watch\Watch.Aspire\Microsoft.DotNet.HotReload.Watch.Aspire.csproj" />
  </ItemGroup>

</Project>