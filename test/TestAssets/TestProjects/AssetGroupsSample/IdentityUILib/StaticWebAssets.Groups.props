<Project>
  <PropertyGroup>
    <IdentityUIFrameworkVersion Condition="'$(IdentityUIFrameworkVersion)' == ''">V5</IdentityUIFrameworkVersion>
  </PropertyGroup>
  <Target Name="_ResolveIdentityUILibStaticWebAssetGroups"
          BeforeTargets="ResolveStaticWebAssetsConfiguration">
    <ItemGroup>
      <StaticWebAssetGroup Include="BootstrapVersion" Value="$(IdentityUIFrameworkVersion)" SourceId="IdentityUILib" />
    </ItemGroup>
  </Target>
</Project>
