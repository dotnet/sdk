<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <Copyright>© Microsoft</Copyright>
    <Product>Framework Assets Test</Product>
    <Company>Microsoft</Company>
    <Description>Library producing framework assets</Description>
    <DeterministicSourcePaths>false</DeterministicSourcePaths>

    <!-- Marks all .js assets as Framework for the pack pipeline -->
    <StaticWebAssetFrameworkPattern>**/*.js</StaticWebAssetFrameworkPattern>

    <!-- Pack to local test feed -->
    <PackageOutputPath>$(MSBuildThisFileDirectory)..\packages</PackageOutputPath>
    <PackageVersion>1.0.0</PackageVersion>
  </PropertyGroup>

  <PropertyGroup>
    <UseRazorBuildServer>false</UseRazorBuildServer>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

</Project>
