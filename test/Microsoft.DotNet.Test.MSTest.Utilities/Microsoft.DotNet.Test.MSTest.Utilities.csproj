<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Shared MSTest-flavored test utilities for SDK test projects.

    This is the MSTest counterpart of the xUnit-based Microsoft.DotNet.HotReload.Test.Utilities
    project. It provides reusable test helpers (TestLogger, TestLoggerFactory, InMemoryLoggerProvider)
    that depend on MSTest's TestContext for output, and therefore cannot live in the xUnit project.

    Consumers: MSTest.Sdk-based test projects in this repo. Add a ProjectReference and use
    `using Microsoft.DotNet.Test.MSTest.Utilities;`.
  -->

  <PropertyGroup>
    <TargetFrameworks>$(SdkTargetFramework);$(NetFrameworkToolCurrent)</TargetFrameworks>
    <OutputType>Library</OutputType>
    <RootNamespace>Microsoft.DotNet.Test.MSTest.Utilities</RootNamespace>
    <StrongNameKeyId>MicrosoftAspNetCore</StrongNameKeyId>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <!-- MSTest.TestFramework version comes from MSTestVersion (Maestro-managed). We use
         VersionOverride because Central Package Management would otherwise require a
         PackageVersion entry in Directory.Packages.props, but MSTest.Sdk also registers its own
         PackageVersion for MSTest.TestFramework (causing NU1506 duplicate). VersionOverride
         sidesteps both. -->
    <PackageReference Include="MSTest.TestFramework" VersionOverride="$(MSTestVersion)" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
  </ItemGroup>

  <!-- System.Collections.Immutable is in-box on .NET (Core); on .NET Framework it ships as a
       NuGet package. Pinned via VersionOverride because System.Collections.Immutable cannot be
       centrally managed in Directory.Packages.props (Roslyn has hard dependencies on specific
       versions that have to work both here and in VS). -->
  <ItemGroup Condition="'$(TargetFrameworkIdentifier)' == '.NETFramework'">
    <PackageReference Include="System.Collections.Immutable" VersionOverride="$(SystemCollectionsImmutableToolsetPackageVersion)" />
  </ItemGroup>

</Project>
