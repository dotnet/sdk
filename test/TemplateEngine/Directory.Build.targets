<Project>

  <Import Project="..\Directory.Build.targets" />

  <ItemGroup Condition="'$(IsTestProject)' == 'true'">
    <!-- TODO: Investigate consolidating TemplateEngine's duplicate types (XunitLoggerProvider,
         DotnetCommand, TestCommand, etc.) with the SDK TestFramework versions.
         https://github.com/dotnet/templating/issues/10085 -->
    <Using Remove="Microsoft.NET.TestFramework" />
    <Using Remove="Microsoft.NET.TestFramework.Commands" />
  </ItemGroup>

</Project>
