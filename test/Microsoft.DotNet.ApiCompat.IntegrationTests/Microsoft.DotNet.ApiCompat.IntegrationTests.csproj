<Project Sdk="MSTest.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(SdkTargetFramework);$(NetFrameworkToolCurrent)</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="$(RepoRoot)src\Compatibility\ApiCompat\Microsoft.DotNet.PackageValidation\Resources.resx" GenerateSource="true" ClassName="Microsoft.DotNet.PackageValidation.Resources" ManifestResourceName="Microsoft.DotNet.PackageValidation.Resources" />
  </ItemGroup>

  <ItemGroup>
    <!-- Build-ordering dependencies on the tools and tasks under test. ReferenceOutputAssembly="false" so we don't take a compile-time dependency. -->
    <ProjectReference Include="$(RepoRoot)src\Compatibility\ApiCompat\Microsoft.DotNet.ApiCompat.Task\Microsoft.DotNet.ApiCompat.Task.csproj" ReferenceOutputAssembly="false" SkipGetTargetFrameworkProperties="true" UndefineProperties="TargetFramework" />
    <ProjectReference Include="$(RepoRoot)src\Compatibility\ApiCompat\Microsoft.DotNet.ApiCompat.Tool\Microsoft.DotNet.ApiCompat.Tool.csproj" ReferenceOutputAssembly="false" SkipGetTargetFrameworkProperties="true" UndefineProperties="TargetFramework" />
    <ProjectReference Include="..\Microsoft.NET.TestFramework.MSTest\Microsoft.NET.TestFramework.MSTest.csproj" />
  </ItemGroup>

  <!-- Stage the apicompat CLI binary closure under tools\Microsoft.DotNet.ApiCompat.Tool\ so the
       test can invoke 'dotnet exec' against it both locally and on Helix. ToolPaths reads the
       DLL relative to AppContext.BaseDirectory; the CopyToOutputDirectory/CopyToPublishDirectory
       metadata makes the tools tree ride along into both the local bin output (used by 'dotnet
       test' with the no-build flag) and the Helix work item payload (which is built from
       PublishDir). -->
  <Target Name="_StageToolsUnderTest" BeforeTargets="AssignTargetPaths">
    <ItemGroup>
      <_ApiCompatToolFile Include="$(ArtifactsBinDir)Microsoft.DotNet.ApiCompat.Tool\$(Configuration)\$(NetMinimum)\**\*" />
      <Content Include="@(_ApiCompatToolFile)"
               Link="tools\Microsoft.DotNet.ApiCompat.Tool\%(_ApiCompatToolFile.RecursiveDir)%(_ApiCompatToolFile.Filename)%(_ApiCompatToolFile.Extension)"
               CopyToOutputDirectory="PreserveNewest"
               CopyToPublishDirectory="PreserveNewest" />
    </ItemGroup>
  </Target>

</Project>
